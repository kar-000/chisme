# Database
DATABASE_URL=postgresql://chisme:password@localhost:5432/chisme

# Security
SECRET_KEY=change-me-to-a-random-32-char-string!!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — add your frontend origin
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# App
DEBUG=False
LOG_LEVEL=INFO

# Redis — presence, pub/sub, HA coordination (Phase 3+)
REDIS_URL=redis://localhost:6379/0

# Server identity — used to namespace Redis keys and qualify user identities.
# Change to your public domain for production deployments.
# Each independent Chisme instance should have a unique value.
SERVER_DOMAIN=localhost

# Deployment domain — used by Caddy (HTTPS reverse proxy) and docker-compose.
# Set to your public domain for production (e.g. DOMAIN=chisme.example.com).
# Caddy auto-provisions Let's Encrypt TLS for real domains; HTTP-only for localhost.
DOMAIN=localhost

# Klipy GIF API — get a free key at partner.klipy.com.
# Leave blank to disable GIF search (silently returns empty results).
TENOR_API_KEY=

# Web Push (VAPID) — required for PWA background push notifications.
# Generate a key pair with: npx web-push generate-vapid-keys
# Then set both values below and VAPID_CLAIMS_EMAIL to a contact address.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@localhost
